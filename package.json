  "workspaces": [
    "backend",
    "frontend"
  ],
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "dependencies": {
    "json2csv": "^6.0.0-alpha.2"
  }
}
