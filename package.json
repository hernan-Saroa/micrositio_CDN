{
  "name": "micrositio-viits",
  "version": "1.0.0",
  "description": "Sistema VIITS - Micrositio INVIAS Colombia",
  "main": "backend/server.js",
  "scripts": {
    "start": "cd backend && npm start",
    "dev": "cd backend && npm run dev",
